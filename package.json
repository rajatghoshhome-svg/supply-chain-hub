{
  "name": "supply-chain-hub",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"cd server && node --watch src/index.js\"",
    "dev:client": "vite",
    "dev:server": "cd server && node --watch src/index.js",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "seed": "cd server && node src/db/seed.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "supertest": "^7.2.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.2"
  }
}
